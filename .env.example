# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  F1 Race Report Tool (Backend)
#
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
#
# How environment variables work in Spring Boot:
#   application.properties reads:  ${DB_PASSWORD:postgres}
#   This means: use the env var DB_PASSWORD, or fall back to "postgres".
#   When you set the env var in your shell / Docker / deployment platform,
#   Spring automatically picks it up without changing any code.
#
# Real-world analogy: like a combination lock. The .env file is the
# secret combination. The .env.example is the diagram showing where
# the dials are, but with placeholder values anyone can see.
# ─────────────────────────────────────────────────────────────────────────────

# ── SERVER ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── POSTGRESQL DATABASE ───────────────────────────────────────────────────────
# Create the DB first: createdb f1reportdb
DB_URL=jdbc:postgresql://localhost:5432/f1reportdb
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ── JPA SETTINGS ─────────────────────────────────────────────────────────────
# Options: create, create-drop, update, validate, none
# Use "update" for development, "validate" or "none" for production
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ── GROQ AI API ───────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
# Free tier includes generous limits (tokens/minute and tokens/day)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Model options (all free on Groq):
#   llama-3.3-70b-versatile  → Best quality, slower
#   llama-3.1-8b-instant     → Fastest, good quality
#   mixtral-8x7b-32768       → Good for longer context
GROQ_MODEL=llama-3.3-70b-versatile

# ── ERGAST/JOLPICA API ────────────────────────────────────────────────────────
# No API key required – Jolpica is free and open
ERGAST_BASE_URL=https://api.jolpi.ca/ergast/f1
